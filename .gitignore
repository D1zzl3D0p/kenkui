# --- Build Artifacts (Generated by 'python -m build') ---
dist/
build/
*.egg-info/
*.egg

# --- Python Cache (Generated when you run the code) ---
__pycache__/
*.pyc
*.pyo
*.pyd

# --- Environments ---
.venv/
venv/
env/
.env

# --- Tool Configuration/Cache ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
htmlcov/

# --- OS Files ---
.DS_Store
Thumbs.db

# --- Kenkui runtime cache ---
.kenkui_cache/

# --- Voice files (hosted on HuggingFace: D1zzl3D0p/kenkui-voices) ---
src/kenkui/voices/*.wav
src/kenkui/voices/compiled-voices/
src/kenkui/voices/uncompiled-voices/

